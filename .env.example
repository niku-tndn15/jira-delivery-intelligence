
# =============================================================================
# .env  —  Jira Analytics Platform
# Copy this file to .env, fill in your values, then run: docker-compose up
# NEVER commit the real .env to version control.
# =============================================================================


# ── Jira credentials ──────────────────────────────────────────────────────────

JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_token_here

#   ↑ Generate at: https://id.atlassian.com/manage-profile/security/api-tokens

# ── Target project ────────────────────────────────────────────────────────────
# The Jira project key to sync on container startup (e.g. PLAT, SHOP)
JIRA_PROJECT_KEY=your_project_name

# ── Optional Jira custom field overrides ──────────────────────────────────────
# Uncomment and set if your instance uses non-default custom field IDs
# JIRA_STORY_POINTS_FIELD=customfield_10028
# JIRA_AC_FIELD=customfield_10016

# ── Database ──────────────────────────────────────────────────────────────────
# Password for the postgres container. The DATABASE_URL is constructed
# automatically in docker-compose.yml — you only need to set the password.
POSTGRES_PASSWORD=your_postgres_password
